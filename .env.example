# =============================================================================
# Reality Intelligence Platform – Environment Variables Template
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Reality Intelligence Platform"
VERSION=1.0.0
ENVIRONMENT=development            # development | staging | production
DEBUG=true
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
SHOW_DOCS=true

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string-in-production

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:rippassword@localhost:5432/rip_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
TEST_DATABASE_URL=postgresql+asyncpg://postgres:rippassword@localhost:5432/rip_test_db

POSTGRES_USER=postgres
POSTGRES_PASSWORD=rippassword
POSTGRES_DB=rip_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage – MinIO (local dev) ────────────────────────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_MEDIA=rip-media
MINIO_BUCKET_MODELS=rip-models
MINIO_BUCKET_OUTPUTS=rip-outputs

# ── Storage – AWS S3 (production) ──────────────────────────────────────────────
# Uncomment and fill for production:
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_S3_BUCKET=rip-production-media
# AWS_REGION=us-east-1

# ── ML Services ────────────────────────────────────────────────────────────────
TRITON_SERVER_URL=localhost:8001
MLFLOW_TRACKING_URI=http://localhost:5000

# Weights & Biases (optional – comment out to disable)
# WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=reality-intelligence-platform

# Model paths (relative to /app/models or absolute)
YOLOV8_MODEL_PATH=models/yolov8_construction.pt
DETECTRON2_MODEL_PATH=models/detectron2_construction.pkl
SAM_MODEL_PATH=models/sam_vit_h_4b8939.pth
DEEPLABV3_MODEL_PATH=models/deeplabv3_construction.pth

# ── COLMAP ──────────────────────────────────────────────────────────────────────
COLMAP_BINARY=colmap
COLMAP_WORKSPACE=/tmp/rip_sfm
RECONSTRUCTION_QUALITY=high        # low | medium | high | extreme

# ── Processing ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=5000
FRAME_EXTRACTION_FPS=2.0
BLUR_THRESHOLD=100.0
SSIM_THRESHOLD=0.95
MAX_FRAMES_PER_VIDEO=5000

# ── Monitoring ─────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Sentry error tracking (optional)
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxx

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@reality-intelligence.io
EMAILS_FROM_NAME="Reality Intelligence Platform"

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# ── Flower (Celery monitoring) ─────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# ── Feature Flags ──────────────────────────────────────────────────────────────
ENABLE_GAUSSIAN_SPLATTING=false
ENABLE_BIM_COMPARISON=true
ENABLE_DELAY_PREDICTION=true
ENABLE_REAL_TIME_PROCESSING=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
ALLOWED_HOSTS=*

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_RECONSTRUCTION=5/hour
RATE_LIMIT_AUTH=20/minute

# ── Airflow ────────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:rippassword@localhost:5432/airflow_db
AIRFLOW__CELERY__BROKER_URL=redis://localhost:6379/3
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://postgres:rippassword@localhost:5432/airflow_db
AIRFLOW__CORE__FERNET_KEY=change-me-generate-with-cryptography
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-random-secret
